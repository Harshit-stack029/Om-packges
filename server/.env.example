# Server
# PORT is provided by Render automatically — do not set in production.
PORT=5000
NODE_ENV=development

# Public site URL — used by sitemap.xml and as the canonical frontend origin.
# Production: https://ompack.rhobel.com
SITE_URL=https://ompack.rhobel.com

# Optional: comma-separated extra origins to allow through CORS at runtime
# (e.g. a preview domain). Production frontend is already allow-listed in code.
# CORS_EXTRA_ORIGINS=https://staging.ompack.rhobel.com

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/om-packaging

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Nodemailer — Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password

# Inquiry delivery
INQUIRY_EMAIL=info@ompack.in
INQUIRY_CC=sales@ompack.in
AUTOREPLY_FROM=OM Packaging <noreply@ompack.in>

# WhatsApp — Twilio (optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX
